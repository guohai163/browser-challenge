FROM envoyproxy/envoy-build-ubuntu@sha256:1b3c82ca34c505c4951918b2e0a0c3db88cf266ebbf4196e4b0fba8fa137ada3 AS envoy-build
WORKDIR /src/envoy

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates git && rm -rf /var/lib/apt/lists/*

ARG ENVOY_REF=main
RUN git clone --depth 1 --branch ${ENVOY_REF} https://github.com/envoyproxy/envoy /src/envoy
COPY script/envoy-patch/envoy-ja3-raw.patch /tmp/envoy-ja3-raw.patch
RUN cd /src/envoy && git apply --3way --whitespace=nowarn /tmp/envoy-ja3-raw.patch

# Build envoy binary with local patches
RUN bazel build -c opt --config=clang //source/exe:envoy-static

FROM rust:1.78-bookworm AS wasm-build
WORKDIR /src
COPY script/h2-fp-plugin ./script/h2-fp-plugin
RUN rustup target add wasm32-unknown-unknown
RUN cargo build --manifest-path ./script/h2-fp-plugin/Cargo.toml --target wasm32-unknown-unknown --release

FROM ubuntu:22.04
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=envoy-build /src/envoy/bazel-bin/source/exe/envoy-static /usr/local/bin/envoy
COPY script/envoy.yml /etc/envoy/envoy.yml
COPY --from=wasm-build /src/script/h2-fp-plugin/target/wasm32-unknown-unknown/release/h2_fp_plugin.wasm /etc/envoy/plugins/h2_fp.wasm

EXPOSE 443 9901
CMD ["envoy", "-c", "/etc/envoy/envoy.yml", "--log-level", "info"]
