+void writeCipherSuitesRaw(const SSL_CLIENT_HELLO* ssl_client_hello, std::string& fingerprint) {
+  CBS cipher_suites;
+  CBS_init(&cipher_suites, ssl_client_hello->cipher_suites, ssl_client_hello->cipher_suites_len);
+
+  bool write_cipher = true;
+  bool first = true;
